#pragma once

#define @PROJECT_VERSION_NAME@_VERSION_MAJOR    @PROJECT_VERSION_MAJOR@
#define @PROJECT_VERSION_NAME@_VERSION_MINOR    @PROJECT_VERSION_MINOR@
#define @PROJECT_VERSION_NAME@_VERSION_PATCH    @PROJECT_VERSION_PATCH@
#define @PROJECT_VERSION_NAME@_VERSION          (@PROJECT_VERSION_NAME@_VERSION_MAJOR << 16 | @PROJECT_VERSION_NAME@_VERSION_MINOR << 8 | @PROJECT_VERSION_NAME@_VERSION_PATCH)
#define @PROJECT_VERSION_NAME@_VERSION_STRING   "@PROJECT_VERSION@"
#define @PROJECT_VERSION_NAME@                  "@CMAKE_SYSTEM_NAME@"
// clang-format on